---
---
<footer class="bg-brand-dark border-t border-white/10">

  <!-- Trust bar -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-4">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-green-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 7V4.5a3 3 0 10-6 0V7M4.5 7h7a1 1 0 011 1v5a1 1 0 01-1 1h-7a1 1 0 01-1-1V8a1 1 0 011-1z"/>
          </svg>
          <span class="text-white/50">TLS 1.3 Encrypted</span>
        </span>
        <span class="hidden sm:block text-white/15">·</span>
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-[#F6821F]">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 10.5a5.5 5.5 0 017.5-5.15M13.5 8a5.5 5.5 0 01-5.5 5.5"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6h3.5V2.5"/>
          </svg>
          <span class="text-white/50">Protected by Cloudflare</span>
        </span>
        <span class="hidden sm:block text-white/15">·</span>
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-[#0078D4]">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 2l3 8H2l3-8h3z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l-2 4h10l-2-4"/>
          </svg>
          <span class="text-white/50">Hosted on Azure India</span>
        </span>
        <span class="hidden sm:block text-white/15">·</span>
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-brand-accent">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 1.5l1.5 4h4l-3.25 2.5 1.25 4L8 9.5l-3.5 2.5 1.25-4L2.5 5.5h4L8 1.5z"/>
          </svg>
          <span class="text-white/50">99.9% uptime SLA</span>
        </span>
        <span class="hidden sm:block text-white/15">·</span>
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-purple-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 14s-6-3.5-6-8a6 6 0 0112 0c0 4.5-6 8-6 8z"/>
          </svg>
          <span class="text-white/50">Data stays in India</span>
        </span>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">

      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-7 h-7 rounded-lg bg-brand-primary flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4">
              <circle cx="9" cy="10" r="3" fill="white" opacity="0.9"/>
              <circle cx="15" cy="7"  r="3.5" fill="white" opacity="0.9"/>
              <circle cx="17" cy="14" r="3" fill="white" opacity="0.9"/>
              <circle cx="10" cy="16" r="2.5" fill="white" opacity="0.9"/>
            </svg>
          </div>
          <span class="text-white font-700 tracking-tight">MySillyDreams</span>
        </div>
        <p class="text-white/40 text-sm leading-relaxed">
          Project management that doesn't get in your way. Built for Indian teams.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-white/70 text-xs font-700 uppercase tracking-widest mb-4">Product</h4>
        <ul class="space-y-3">
          <li><a href="/#features" class="text-white/40 text-sm hover:text-white transition-colors">Features</a></li>
          <li><a href="/#pricing" class="text-white/40 text-sm hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/#security" class="text-white/40 text-sm hover:text-white transition-colors">Security</a></li>
          <li><a href="https://pm.mysillydreams.com/login" class="text-white/40 text-sm hover:text-white transition-colors">Sign In</a></li>
        </ul>
      </div>

      <!-- Security & Compliance -->
      <div>
        <h4 class="text-white/70 text-xs font-700 uppercase tracking-widest mb-4">Security</h4>
        <ul class="space-y-3">
          <li><span class="text-white/40 text-sm flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Role-based access control</span></li>
          <li><span class="text-white/40 text-sm flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Two-factor authentication</span></li>
          <li><span class="text-white/40 text-sm flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Full audit trail</span></li>
          <li><span class="text-white/40 text-sm flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Client data isolation</span></li>
          <li><span class="text-white/40 text-sm flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Automated backups</span></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-white/70 text-xs font-700 uppercase tracking-widest mb-4">Legal</h4>
        <ul class="space-y-3">
          <li><a href="https://mysillydreams.com/legal/privacy/" class="text-white/40 text-sm hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="https://mysillydreams.com/terms-of-service/" class="hover:text-white transition-colors text-white/40 text-sm">Terms of Service</a></li>
          <li><a href="mailto:support@mysillydreams.com" class="text-white/40 text-sm hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/25">
        © {new Date().getFullYear()} MySillyDreams. All rights reserved. Made in India 🇮🇳
      </p>
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1.5 text-xs text-white/25">
          <svg viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3 text-green-400">
            <circle cx="6" cy="6" r="3"/>
          </svg>
          All systems operational
        </span>
      </div>
    </div>
  </div>

</footer>
