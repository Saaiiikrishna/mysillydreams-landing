---
---
<footer class="bg-brand-dark border-t border-white/10">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg bg-brand-primary flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4">
            <circle cx="9" cy="10" r="3" fill="white" opacity="0.9"/>
            <circle cx="15" cy="7"  r="3.5" fill="white" opacity="0.9"/>
            <circle cx="17" cy="14" r="3" fill="white" opacity="0.9"/>
            <circle cx="10" cy="16" r="2.5" fill="white" opacity="0.9"/>
          </svg>
        </div>
        <span class="text-white font-700 tracking-tight">MySillyDreams</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-white/50">
        <a href="https://mysillydreams.com/legal/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="https://mysillydreams.com/terms-of-service/" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="https://pm.mysillydreams.com/login" class="hover:text-white transition-colors">Sign In</a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-white/30">
        © {new Date().getFullYear()} MySillyDreams. All rights reserved.
      </p>
    </div>
  </div>
</footer>
