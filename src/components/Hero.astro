---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-primary to-brand-accent opacity-95"></div>
  <!-- Subtle grid overlay -->
  <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <!-- Glow blobs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500 rounded-full filter blur-3xl opacity-20"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-indigo-400 rounded-full filter blur-3xl opacity-20"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/80 text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Built for modern B2B teams
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl font-800 text-white leading-tight tracking-tight mb-6">
      Project management<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-200 to-indigo-200">
        that gets out of your way
      </span>
    </h1>

    <!-- Sub -->
    <p class="text-xl md:text-2xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
      Plan sprints, track work, and ship faster — together. Boards, backlogs, timelines, and reports, all in one place.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://pm.mysillydreams.com/login"
        class="px-8 py-4 rounded-xl bg-white text-brand-primary font-700 text-lg hover:bg-brand-light transition-all shadow-xl hover:shadow-2xl hover:-translate-y-0.5"
      >
        Start managing work →
      </a>
      <a
        href="#features"
        class="px-8 py-4 rounded-xl bg-white/10 border border-white/20 text-white font-600 text-lg hover:bg-white/20 transition-all backdrop-blur"
      >
        See how it works
      </a>
    </div>

    <!-- Social proof strip -->
    <p class="mt-12 text-white/40 text-sm">Trusted by growing B2B teams · No credit card required</p>
  </div>
</section>
